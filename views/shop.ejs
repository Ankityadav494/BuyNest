<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Product</title>
    <script src="https://cdn.tailwindcss.com"></script>
   <link rel="stylesheet" href="/stylesheets/style.css">

</head>
<body class="bg-gray-100 min-h-screen flex">

    <!-- Sidebar -->
    <aside class="w-1/5 bg-white p-6 space-y-6 shadow-sm transition-shadow duration-300 hover:shadow-md">
         <h1 class="text-4xl text-left px-4 font-bold text-gray-800 hover:text-blue-600 transition-colors duration-300 cursor-default">BuyNest</h1>
         <% if (typeof user !== 'undefined' && user) { %>
         <div class="px-4 py-2 bg-blue-50 rounded-lg transition-all duration-300 hover:bg-blue-100 border border-blue-100">
           <p class="text-sm text-gray-600">Hello, <span class="font-semibold text-blue-700"><%= user.fullname %></span></p>
           <a href="/logout" class="text-sm text-red-600 hover:text-red-700 hover:underline mt-1 inline-block transition-all duration-200">Logout</a>
         </div>
         <% } %>

        <!-- Sort by -->
        <div>
            <label for="sort" class="block mb-2 text-sm font-medium">Sort by</label>
            <select id="sort" class="w-full border border-gray-300 rounded-lg px-3 py-2 transition-all duration-200 focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-200 cursor-pointer hover:border-gray-400">
                <option>Popular</option>
                <option>Newest</option>
                <option>Price: Low to High</option>
                <option>Price: High to Low</option>
            </select>
        </div>

        <!-- Categories -->
        <div class="space-y-1">
            <p class="font-semibold">Collections</p>
            <ul class="space-y-1 text-sm">
                <li class="nav-item" data-category="new">New Collection</li>
                <li class="nav-item active" data-category="all">All Products</li>
                <li class="nav-item" data-category="discounted">Discounted Products</li>
            </ul>
        </div>

        <!-- Filter -->
        <div class="space-y-1">
            <p class="font-semibold">Filter by</p>
            <ul class="space-y-1 text-sm">
                <li class="nav-item" data-filter="availability">Availability</li>
                <li class="nav-item" data-filter="discount">Discount</li>
            </ul>
        </div>
    </aside>

    <!-- Product Grid -->
    <main class="flex-1 p-6 grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        <!-- Product Card -->
        <div class="product-card bg-yellow-400 rounded-xl overflow-hidden flex flex-col justify-between min-h-[200px]">
            <div class="flex-1 flex items-center justify-center text-4xl">🛍</div>
            <div class="bg-red-500 p-3 flex justify-between items-center">
                <div>
                    <p class="text-sm font-medium text-white">Clinge Bag</p>
                    <p class="text-sm font-semibold text-white">₹ 1200</p>
                </div>
                <button class="add-btn bg-white w-8 h-8 rounded-full flex items-center justify-center text-lg font-bold text-red-500 shadow hover:shadow-md">+</button>
            </div>
        </div>

        <div class="product-card bg-blue-300 rounded-xl overflow-hidden flex flex-col justify-between min-h-[200px]">
            <div class="flex-1 flex items-center justify-center text-4xl">👕</div>
            <div class="bg-indigo-600 p-3 flex justify-between items-center">
                <div>
                    <p class="text-sm font-medium text-white">Classic Tee</p>
                    <p class="text-sm font-semibold text-white">₹ 899</p>
                </div>
                <button class="add-btn bg-white w-8 h-8 rounded-full flex items-center justify-center text-lg font-bold text-indigo-600 shadow hover:shadow-md">+</button>
            </div>
        </div>

        <div class="product-card bg-green-300 rounded-xl overflow-hidden flex flex-col justify-between min-h-[200px]">
            <div class="flex-1 flex items-center justify-center text-4xl">👟</div>
            <div class="bg-emerald-600 p-3 flex justify-between items-center">
                <div>
                    <p class="text-sm font-medium text-white">Sneakers</p>
                    <p class="text-sm font-semibold text-white">₹ 2499</p>
                </div>
                <button class="add-btn bg-white w-8 h-8 rounded-full flex items-center justify-center text-lg font-bold text-emerald-600 shadow hover:shadow-md">+</button>
            </div>
        </div>

        <div class="product-card bg-pink-300 rounded-xl overflow-hidden flex flex-col justify-between min-h-[200px]">
            <div class="flex-1 flex items-center justify-center text-4xl">⌚</div>
            <div class="bg-rose-600 p-3 flex justify-between items-center">
                <div>
                    <p class="text-sm font-medium text-white">Smart Watch</p>
                    <p class="text-sm font-semibold text-white">₹ 3499</p>
                </div>
                <button class="add-btn bg-white w-8 h-8 rounded-full flex items-center justify-center text-lg font-bold text-rose-600 shadow hover:shadow-md">+</button>
            </div>
        </div>
    </main>

    <script>
      document.querySelectorAll('.nav-item').forEach(el => {
        el.addEventListener('click', function() {
          document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
          this.classList.add('active');
        });
      });
      document.getElementById('sort').addEventListener('change', function() {
        this.classList.add('opacity-80');
        setTimeout(() => this.classList.remove('opacity-80'), 200);
      });
    </script>
</body>
</html>
